	}

	@Override
	public Company retrieveCompanyById(Long id) {
		return comprepo.findById(id).orElseThrow(()-> new ResourceNotFoundException("No COmpany found for given ID "+id));
		
	}

	@Override
	public List<Company> getAllCompanies() {
